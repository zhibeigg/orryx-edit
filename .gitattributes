* text=auto

# POSIX scripts and source files use LF.
*.sh text eol=lf
gradlew text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf
VERSION text eol=lf
*.kt text eol=lf
*.kts text eol=lf
*.java text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.properties text eol=lf

# Native Windows launchers use CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary artifacts must never be normalized.
*.jar binary
*.zip binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
