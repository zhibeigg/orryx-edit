PORT=9090
ADMIN_KEY=replace-with-at-least-16-random-characters
DATA_DIR=/var/lib/orryx-editor
DATABASE_URL=r2dbc:postgresql://127.0.0.1:5432/orryx_editor
DATABASE_USER=orryx
DATABASE_PASSWORD=replace-with-a-strong-password
DB_POOL_MIN_IDLE=1
DB_POOL_MAX_SIZE=10
DEPLOYMENT_MODE=launcher
ORRYX_JAR=/opt/orryx-editor/orryx-editor.jar
UPDATE_ENABLED=true
UPDATE_GITHUB_REPOSITORY=zhibeigg/orryx-edit
UPDATE_GITHUB_TOKEN=
UPDATE_STAGING_DIR=/var/lib/orryx-editor/updates
INSTANCE_ID=orryx-editor-production
HSTS_ENABLED=true
CORS_HOSTS=
TRUSTED_PROXY_IPS=127.0.0.1
