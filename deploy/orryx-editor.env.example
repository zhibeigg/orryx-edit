PORT=9090
ADMIN_KEY=replace-with-at-least-16-random-characters
DATA_DIR=/var/lib/orryx-editor
DATABASE_URL=r2dbc:postgresql://127.0.0.1:5432/orryx_editor
DATABASE_USER=orryx
DATABASE_PASSWORD=replace-with-a-strong-password
DB_POOL_MIN_IDLE=1
DB_POOL_MAX_SIZE=10
DB_CONNECT_TIMEOUT_SECONDS=10
DB_STATEMENT_TIMEOUT_SECONDS=30
LEGACY_LICENSE_FILE=/var/lib/orryx-editor/licenses.json

EDITOR_SESSION_TTL_HOURS=24
EDITOR_SESSION_CLEANUP_MINUTES=15
RELAY_REQUEST_TIMEOUT_SECONDS=15
EDITOR_PROTOCOL_V2_ENABLED=false
EDITOR_V2_WRITES_ENABLED=false

ACCOUNTS_ENABLED=false
CLOUD_DRAFTS_ENABLED=false
ALIPAY_ENABLED=false
RUNNER_ENABLED=false
AI_WORKBENCH_ENABLED=false
RELEASE_TRANSACTIONS_ENABLED=false
ACCOUNT_SESSION_TTL_HOURS=168
ACCOUNT_COOKIE_SECURE=true
ACCOUNT_COOKIE_DOMAIN=

RELEASE_PUBLIC_BASE_URL=https://editor.example.com
RELEASE_ALLOW_LOCAL_HTTP=false
RELEASE_SIGNING_PRIVATE_KEY_PKCS8_BASE64=
RELEASE_SIGNING_PUBLIC_KEY_X509_BASE64=
RELEASE_TRANSFER_TTL_SECONDS=300
RELEASE_TRANSACTION_LEASE_SECONDS=30
RELEASE_READINESS_TIMEOUT_SECONDS=180
RELEASE_MAX_BYTES=67108864

AI_PROVIDER_ID=default
AI_PROVIDER_BASE_URL=https://api.openai.com/v1
AI_PROVIDER_API_KEY=
AI_PROVIDER_MODEL=
AI_PROVIDER_REQUEST_TIMEOUT_SECONDS=60
AI_PROVIDER_MAX_RESPONSE_BYTES=2097152
AI_INPUT_COST_PER_MILLION_CENTS=0
AI_OUTPUT_COST_PER_MILLION_CENTS=0
AI_USAGE_RESERVATION_CENTS=100

RUNNER_ENDPOINT=http://127.0.0.1:9781/v1/run
RUNNER_SHARED_SECRET=
RUNNER_REQUEST_TIMEOUT_SECONDS=60
RUNNER_MAX_RESPONSE_BYTES=4194304

DEPLOYMENT_MODE=launcher
ORRYX_JAR=/opt/orryx-editor/orryx-editor.jar
UPDATE_ENABLED=true
UPDATE_GITHUB_REPOSITORY=zhibeigg/orryx-edit
UPDATE_GITHUB_TOKEN=
UPDATE_CHANNEL=stable
UPDATE_STAGING_DIR=/var/lib/orryx-editor/updates
UPDATE_MAX_BYTES=268435456
UPDATE_CHECK_CACHE_SECONDS=300
UPDATE_ALLOWED_HOSTS=api.github.com,github.com,objects.githubusercontent.com,github-releases.githubusercontent.com
KETHER_DOCS_SYNC_ENABLED=true
KETHER_DOCS_SYNC_INTERVAL_HOURS=12
KETHER_DOCS_REQUEST_TIMEOUT_SECONDS=20
KETHER_DOCS_MAX_SCHEMA_BYTES=4194304
INSTANCE_ID=orryx-editor-production
BUILD_COMMIT=unknown
HSTS_ENABLED=true
CORS_HOSTS=
TRUSTED_PROXY_IPS=127.0.0.1
