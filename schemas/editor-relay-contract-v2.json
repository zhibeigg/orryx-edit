{
  "contractVersion": 2,
  "protocolVersions": ["v1", "v2"],
  "directions": {
    "browserToRelay": [
      "auth",
      "session.resume",
      "file.list",
      "file.read",
      "file.write",
      "file.create",
      "file.delete",
      "file.rename",
      "reload",
      "log.subscribe",
      "log.unsubscribe",
      "presence.update",
      "manifest.get"
    ],
    "relayToPlugin": [
      "server.register.result",
      "token.register.result",
      "token.revoke.result",
      "error",
      "file.list",
      "file.read",
      "file.write",
      "file.create",
      "file.delete",
      "file.rename",
      "reload",
      "log.subscribe",
      "log.unsubscribe",
      "manifest.get",
      "release.request"
    ],
    "pluginToRelay": [
      "server.register",
      "token.register",
      "token.revoke",
      "file.tree",
      "file.content",
      "file.written",
      "file.changed",
      "reload.result",
      "log.subscribe.result",
      "log.unsubscribe.result",
      "log.entry",
      "server.info",
      "manifest.snapshot",
      "release.result",
      "error"
    ],
    "relayToBrowser": [
      "auth.result",
      "session.resume.result",
      "file.tree",
      "file.content",
      "file.written",
      "file.changed",
      "presence.update.result",
      "presence.updated",
      "reload.result",
      "log.subscribe.result",
      "log.unsubscribe.result",
      "log.entry",
      "server.info",
      "manifest.snapshot",
      "error"
    ]
  },
  "v2": {
    "revisionPattern": "^[0-9a-f]{64}$",
    "browserWriteRevisionField": "baseRevision",
    "pluginWriteRevisionField": "expectedRevision",
    "mutations": [
      "file.write",
      "file.create",
      "file.delete",
      "file.rename",
      "reload"
    ],
    "manifest": {
      "requestType": "manifest.get",
      "responseType": "manifest.snapshot",
      "maxFiles": 4096,
      "pathNormalization": "relative-forward-slash",
      "duplicatePathComparison": "case-insensitive-normalized",
      "fileRevisionField": "revision",
      "manifestRevisionField": "revision",
      "sizeMinimum": 0
    },
    "pluginError": {
      "forwardedFields": ["code", "path", "currentRevision", "requestType"],
      "fallbackCode": "PLUGIN_ERROR",
      "safeCodes": [
        "REQUEST_FAILED",
        "INVALID_MESSAGE",
        "INVALID_DATA",
        "MESSAGE_DIRECTION_NOT_ALLOWED",
        "UNKNOWN_MESSAGE_TYPE",
        "NOT_REGISTERED",
        "MESSAGE_NOT_SUPPORTED",
        "UNHANDLED_MESSAGE_TYPE",
        "RELAY_CAPABILITY_MISSING",
        "FILE_POLICY_VIOLATION",
        "REVISION_CONFLICT",
        "PRECONDITION_FAILED",
        "CASE_CONFLICT",
        "MUTATION_GATE_ACTIVE",
        "REQUEST_QUEUE_FULL",
        "REVISION_FIELDS_MISMATCH",
        "REVISION_REQUIRED",
        "FILE_NOT_FOUND",
        "FILE_ALREADY_EXISTS",
        "PATH_TYPE_MISMATCH",
        "PERMISSION_DENIED",
        "READ_ONLY",
        "UNSUPPORTED_OPERATION",
        "FILE_TOO_LARGE",
        "INVALID_PATH",
        "INVALID_REVISION",
        "RELOAD_FAILED",
        "MANIFEST_UNAVAILABLE",
        "READINESS_FAILED",
        "ROLLBACK_FAILED",
        "ROLLBACK_RELOAD_FAILED",
        "ROLLBACK_MANIFEST_MISMATCH",
        "RECOVERY_AMBIGUOUS",
        "INVALID_JOURNAL",
        "RECOVERY_SCAN_FAILED",
        "RELEASE_REQUEST_FAILED"
      ]
    },
    "requiredPluginCapabilities": ["revision.sha256", "file.write.v2"],
    "requiredMutationCapabilities": ["mutation.preconditions"],
    "requiredReleasePluginCapabilities": [
      "release.transaction.v1",
      "release.signature.ed25519",
      "release.readiness.async",
      "release.recovery.v1",
      "release.http-pull.v1"
    ],
    "relayRevisionCapability": "revision.sha256",
    "relayWriteCapability": "file.write.v2",
    "relayReleaseCapability": "release.control.v1",
    "releaseOperationsSemantics": "complete-target-snapshot",
    "releaseRequestActions": ["prepare", "commit", "status", "rollback"],
    "releasePluginStates": [
      "PREPARING",
      "PREPARED",
      "COMMITTING",
      "READINESS_PENDING",
      "READY",
      "ROLLING_BACK",
      "ROLLED_BACK",
      "FAILED",
      "RECOVERY_REQUIRED"
    ]
  },
  "reservedUnroutedTypes": []
}
