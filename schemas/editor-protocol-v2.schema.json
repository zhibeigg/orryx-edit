{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orryx.dev/schemas/editor-protocol-v2.schema.json",
  "title": "Orryx Editor Relay Protocol V2",
  "description": "V2 identity, SHA revision and signed release transaction contracts.",
  "type": "object",
  "$defs": {
    "protocolVersion": {
      "type": "string",
      "enum": ["v1", "v2"]
    },
    "sha256Revision": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "capability": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9._-]{0,63}$"
    },
    "messageEnvelope": {
      "type": "object",
      "required": ["type", "id", "data"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9._-]{0,63}$"
        },
        "id": {
          "type": "string",
          "maxLength": 128
        },
        "data": {
          "type": "object"
        }
      }
    },
    "serverRegisterData": {
      "type": "object",
      "required": ["license", "serverName"],
      "additionalProperties": true,
      "properties": {
        "license": { "type": "string", "minLength": 8, "maxLength": 512 },
        "serverName": { "type": "string", "minLength": 1, "maxLength": 100 },
        "serverId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" },
        "pluginVersion": { "type": "string", "minLength": 1, "maxLength": 64 },
        "protocolVersions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/protocolVersion" }
        },
        "preferredProtocol": { "$ref": "#/$defs/protocolVersion" },
        "capabilities": {
          "type": "array",
          "maxItems": 64,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/capability" }
        },
        "connectionNonce": { "type": "string", "minLength": 8, "maxLength": 128 }
      }
    },
    "serverRegisterResultData": {
      "type": "object",
      "required": ["success"],
      "additionalProperties": true,
      "properties": {
        "success": { "type": "boolean" },
        "serverKey": { "type": "string" },
        "serverId": { "type": "string" },
        "serverInstanceId": { "$ref": "#/$defs/uuid" },
        "workspaceId": { "$ref": "#/$defs/sha256Revision" },
        "negotiatedProtocol": { "$ref": "#/$defs/protocolVersion" },
        "sessionEpoch": { "type": "integer", "minimum": 1 },
        "relayCapabilities": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/capability" }
        },
        "connectionNonce": { "type": ["string", "null"] },
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    },
    "v2BrowserFileWriteData": {
      "type": "object",
      "required": ["path", "content"],
      "additionalProperties": true,
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "content": { "type": "string" },
        "baseRevision": { "$ref": "#/$defs/sha256Revision" },
        "force": { "type": "boolean", "default": false }
      },
      "not": { "required": ["expectedRevision"] }
    },
    "v2PluginFileWriteData": {
      "type": "object",
      "required": ["path", "content"],
      "additionalProperties": true,
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "content": { "type": "string" },
        "expectedRevision": { "$ref": "#/$defs/sha256Revision" },
        "force": { "type": "boolean", "default": false }
      },
      "not": { "required": ["baseRevision"] }
    },
    "manifestSnapshotFile": {
      "type": "object",
      "required": ["path", "revision"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "revision": { "$ref": "#/$defs/sha256Revision" },
        "size": { "type": "integer", "minimum": 0 }
      }
    },
    "manifestSnapshotData": {
      "type": "object",
      "required": ["manifestId", "revision", "files"],
      "additionalProperties": false,
      "properties": {
        "manifestId": { "type": "string", "minLength": 1, "maxLength": 128 },
        "revision": { "$ref": "#/$defs/sha256Revision" },
        "files": {
          "type": "array",
          "items": { "$ref": "#/$defs/manifestSnapshotFile" }
        },
        "createdAt": { "type": "integer", "minimum": 0 }
      }
    },
    "releaseFile": {
      "type": "object",
      "required": ["ordinal", "path", "contentRevision", "size", "contentUrl"],
      "additionalProperties": false,
      "properties": {
        "ordinal": { "type": "integer", "minimum": 0 },
        "path": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "baseRevision": {
          "oneOf": [
            { "$ref": "#/$defs/sha256Revision" },
            { "type": "null" }
          ]
        },
        "contentRevision": { "$ref": "#/$defs/sha256Revision" },
        "size": { "type": "integer", "minimum": 0 },
        "contentUrl": { "type": "string", "format": "uri", "maxLength": 2048 }
      }
    },
    "releaseRequestData": {
      "type": "object",
      "required": ["action", "transactionId", "releaseId", "commandId"],
      "additionalProperties": false,
      "properties": {
        "action": { "type": "string", "enum": ["prepare", "commit", "status", "rollback"] },
        "transactionId": { "$ref": "#/$defs/uuid" },
        "releaseId": { "$ref": "#/$defs/uuid" },
        "commandId": { "$ref": "#/$defs/sha256Revision" },
        "canonicalVersion": { "type": "string", "const": "orryx-release-v1" },
        "canonicalPayloadSha256": { "$ref": "#/$defs/sha256Revision" },
        "signingKeyId": { "$ref": "#/$defs/sha256Revision" },
        "signature": { "type": "string", "pattern": "^[A-Za-z0-9_-]{86}$" },
        "expectedManifestRevision": { "$ref": "#/$defs/sha256Revision" },
        "targetManifestRevision": { "$ref": "#/$defs/sha256Revision" },
        "fileCount": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "totalBytes": { "type": "integer", "minimum": 0, "maximum": 67108864 },
        "operationsUrl": { "type": "string", "format": "uri", "maxLength": 2048 },
        "transferToken": { "type": "string", "minLength": 40, "maxLength": 256 },
        "transferExpiresAt": { "type": "integer", "minimum": 1 },
        "readinessDeadline": { "type": "integer", "minimum": 1 },
        "reason": { "type": "string", "maxLength": 160 }
      }
    },
    "releaseResultData": {
      "type": "object",
      "required": ["action", "transactionId", "releaseId", "commandId", "success", "pluginState", "eventId", "eventSeq"],
      "additionalProperties": false,
      "properties": {
        "action": { "type": "string", "enum": ["prepare", "commit", "status", "rollback"] },
        "transactionId": { "$ref": "#/$defs/uuid" },
        "releaseId": { "$ref": "#/$defs/uuid" },
        "commandId": { "$ref": "#/$defs/sha256Revision" },
        "success": { "type": "boolean" },
        "pluginState": {
          "type": "string",
          "enum": ["PREPARING", "PREPARED", "COMMITTING", "READINESS_PENDING", "READY", "ROLLING_BACK", "ROLLED_BACK", "FAILED", "RECOVERY_REQUIRED"]
        },
        "eventId": { "$ref": "#/$defs/uuid" },
        "eventSeq": { "type": "integer", "minimum": 1 },
        "observedManifestRevision": { "$ref": "#/$defs/sha256Revision" },
        "resultManifestRevision": { "$ref": "#/$defs/sha256Revision" },
        "errorCode": { "type": "string", "maxLength": 100 },
        "message": { "type": "string", "maxLength": 1000 }
      }
    }
  },
  "properties": {
    "serverRegister": { "$ref": "#/$defs/serverRegisterData" },
    "serverRegisterResult": { "$ref": "#/$defs/serverRegisterResultData" },
    "v2BrowserFileWrite": { "$ref": "#/$defs/v2BrowserFileWriteData" },
    "v2PluginFileWrite": { "$ref": "#/$defs/v2PluginFileWriteData" },
    "manifestSnapshot": { "$ref": "#/$defs/manifestSnapshotData" },
    "releaseFile": { "$ref": "#/$defs/releaseFile" },
    "releaseRequest": { "$ref": "#/$defs/releaseRequestData" },
    "releaseResult": { "$ref": "#/$defs/releaseResultData" }
  }
}
